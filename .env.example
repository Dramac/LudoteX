# =====================================================================
# Modèle de configuration — copier en .env et renseigner les valeurs.
# Ne JAMAIS committer le fichier .env (il est ignoré par git).
# =====================================================================

# --- Jeton d'écriture bénévole ---------------------------------------
# Jeton aléatoire long (~32 caractères) autorisant les opérations de
# prêt/retour. Distribué une fois par an aux bénévoles, mémorisé côté
# appareil. À régénérer à chaque édition (rotation annuelle).
# Générer une valeur :  python -c "import secrets; print(secrets.token_urlsafe(32))"
PRET_TOKEN=remplacer_par_un_jeton_aleatoire_long

# --- Base de données -------------------------------------------------
# Chemin du fichier SQLite. Reste hors du dépôt (dossier data/ ignoré).
DATABASE_PATH=data/pret-jeux.db

# --- Domaine / URL publique ------------------------------------------
# Utilisé pour construire les URL encodées dans les QR : <BASE_URL>/jeu/<id_exemplaire>
# Ex. https://pret.mon-asso.fr
BASE_URL=https://pret.example.fr

# --- Limitation de débit (écriture) ----------------------------------
# Nombre maximal de tentatives d'écriture par minute et par IP.
RATE_LIMIT_PER_MINUTE=60

# --- Environnement ---------------------------------------------------
# development | production
APP_ENV=development
